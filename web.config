<?xml version="1.0" encoding="UTF-8"?>
<configuration>
  <system.webServer>
    <directoryBrowse enabled="false" />
    <defaultDocument>
      <files>
        <clear />
        <add value="index.html" />
      </files>
    </defaultDocument>
    <rewrite>
      <rules>
        <rule name="HTM to HTML" stopProcessing="true">
          <match url="^(.+)\.htm$" ignoreCase="true" />
          <action type="Redirect" url="/{R:1}.html" redirectType="Permanent" />
        </rule>

        <rule name="DefaultASP" stopProcessing="true">
          <match url="^default\.asp$" ignoreCase="true" />
          <action type="Redirect" url="/" redirectType="Permanent" />
        </rule>

        <rule name="f1997recap\.html" stopProcessing="true">
